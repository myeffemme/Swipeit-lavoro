---
interface Props {
  title: string
  description?: string
}
const {
  title,
  description = 'Inchieste, dati e analisi sul lavoro in Italia. A cura del team di SwipeIt.',
} = Astro.props
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark">SwipeIt</span><span class="brand-sub">Lavoro</span>
      </a>
      <nav class="nav">
        <a href="/">Articoli</a>
        <a href="/pa" class="soon">Concorsi PA</a>
        <a href="/onu" class="soon">Lavoro ONU</a>
      </nav>
      <a class="cta" href="#scarica">Scarica l'app</a>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>SwipeIt Lavoro — osservatorio sul lavoro in Italia.</p>
      <p class="muted">© 2026 SwipeIt · <a href="https://swipeit.it">swipeit.it</a></p>
    </footer>

    <style is:global>
      :root {
        --rust: #d87721;
        --rust-bright: #ff7a1a;
        --ink: #1c1a17;
        --muted: #6b655c;
        --bg: #faf7f2;
        --card: #ffffff;
        --border: #e7e0d6;
        --maxw: 760px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font: 17px/1.65 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
      }
      a { color: inherit; }
      .site-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1rem 1.25rem;
      }
      .brand { text-decoration: none; font-weight: 800; letter-spacing: -0.02em; }
      .brand-mark { color: var(--rust); }
      .brand-sub { color: var(--ink); margin-left: 0.25rem; font-weight: 700; }
      .nav { display: flex; gap: 1rem; margin-left: auto; font-size: 0.95rem; }
      .nav a { text-decoration: none; color: var(--muted); }
      .nav a:hover { color: var(--ink); }
      .nav .soon { opacity: 0.5; }
      .cta {
        text-decoration: none;
        background: var(--rust);
        color: #fff;
        font-weight: 600;
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        font-size: 0.9rem;
        white-space: nowrap;
      }
      .cta:hover { background: var(--rust-bright); }
      .site-main { max-width: var(--maxw); margin: 0 auto; padding: 1rem 1.25rem 4rem; }
      .site-footer {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem 3rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.9rem;
      }
      .muted { color: var(--muted); }
      @media (max-width: 560px) {
        .nav { display: none; }
      }
    </style>
  </body>
</html>
