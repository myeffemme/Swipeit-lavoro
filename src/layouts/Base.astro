---
interface Props {
  title: string
  description?: string
}
const {
  title,
  description = 'Inchieste, dati e analisi sul lavoro in Italia. My Italian Job.',
} = Astro.props

const path = Astro.url.pathname
function attiva(href: string): boolean {
  return href === '/' ? path === '/' : path.startsWith(href)
}
const voci = [
  { href: '/post', label: 'Post' },
  { href: '/longform', label: 'LongForm' },
  { href: '/dal-mondo', label: 'Dal Mondo' },
  { href: '/storia', label: 'Storia' },
  { href: '/trend', label: 'Trend' },
  { href: '/lavoro', label: 'Lavoro' },
]
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="myitalianjob — home"
        ><span class="b-my">my</span><span class="b-it">italian</span><span
          class="b-job">job</span
        ></a
      >
      <nav class="nav">
        {
          voci.map((v) => (
            <a href={v.href} class={attiva(v.href) ? 'on' : ''} aria-current={attiva(v.href) ? 'page' : undefined}>
              {v.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>My Italian Job — osservatorio sul lavoro in Italia.</p>
      <p class="muted">© 2026 My Italian Job</p>
    </footer>

    <style is:global>
      :root {
        --rust: #d87721;
        --rust-bright: #ff7a1a;
        --saffron: #f4b41a;
        --ink: #1c1a17;
        --muted: #6b655c;
        --bg: #faf7f2;
        --card: #ffffff;
        --border: #e7e0d6;
        --maxw: 760px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font: 17px/1.65 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
      }
      a { color: inherit; }
      .site-header {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.6rem 1.25rem;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1rem 1.25rem;
      }
      .brand {
        text-decoration: none;
        font-size: 1.55rem;
        letter-spacing: -0.03em;
        line-height: 1;
      }
      .b-my { color: var(--ink); font-weight: 800; }
      .b-it { color: var(--rust); font-weight: 800; }
      .b-job {
        color: var(--saffron);
        font-style: italic;
        font-weight: 700;
        font-family: Georgia, 'Times New Roman', serif;
      }
      .nav { display: flex; gap: 1.1rem; margin-left: auto; font-size: 0.95rem; }
      .nav a {
        text-decoration: none;
        color: var(--muted);
        padding-bottom: 2px;
        border-bottom: 2px solid transparent;
      }
      .nav a:hover { color: var(--ink); }
      .nav a.on { color: var(--ink); font-weight: 700; border-bottom-color: var(--rust); }
      .site-main { max-width: var(--maxw); margin: 0 auto; padding: 1rem 1.25rem 4rem; }
      .site-footer {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem 3rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.9rem;
      }
      .muted { color: var(--muted); }
      @media (max-width: 560px) {
        .nav {
          width: 100%;
          margin-left: 0;
          gap: 0.9rem;
          flex-wrap: wrap;
          font-size: 0.9rem;
        }
      }
    </style>
  </body>
</html>
