---
import Base from '../../layouts/Base.astro'
import { marked } from 'marked'
import ShareButtons from '../../components/ShareButtons.astro'
import Tag from '../../components/Tag.astro'
import {
  fetchArticoli,
  articoloSlug,
  dataItaliana,
  etichettaRubrica,
  tagsDiArticolo,
  type Articolo,
  type Fonte,
} from '../../lib/supabase'

export async function getStaticPaths() {
  const articoli = await fetchArticoli()
  return articoli.map((a) => ({ params: { slug: articoloSlug(a) }, props: { a } }))
}

const { a } = Astro.props as { a: Articolo }
const html = a.testo_markdown ? await marked.parse(a.testo_markdown) : ''
const fonti: Fonte[] = Array.isArray(a.fonti) ? a.fonti : []
const tags = tagsDiArticolo(a)
const rubrica = etichettaRubrica(a)
const urlAssoluto = new URL(`/articolo/${articoloSlug(a)}`, Astro.site).href

function etichettaFonte(f: Fonte): string {
  return f.titolo ?? f.title ?? f.url ?? 'Fonte'
}
---

<Base title={`${a.argomento} — My Italian Job`} description={a.argomento}>
  <article class="post">
    <a class="back" href="/post">← Tutti i post</a>

    <div class="post-meta">
      <time>{dataItaliana(a.data_sessione)}</time>
      {rubrica && <span class="kind">{rubrica}</span>}
      {a.stato !== 'ACTIVE' && <span class="badge">{a.stato}</span>}
    </div>

    <h1>{a.argomento}</h1>

    <div class="post-tags">
      {tags.map((t) => <Tag tag={t} size="sm" />)}
    </div>

    <div class="prose" set:html={html} />

    {
      fonti.length > 0 && (
        <section class="fonti">
          <h2>Fonti</h2>
          <ul>
            {fonti.map((f) => (
              <li>
                {f.url ? (
                  <a href={f.url} target="_blank" rel="noopener">
                    {etichettaFonte(f)}
                  </a>
                ) : (
                  <span>{etichettaFonte(f)}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <ShareButtons url={urlAssoluto} title={a.argomento} />
  </article>

  <style>
    .post { padding-top: 0.5rem; }
    .back { color: var(--muted); text-decoration: none; font-size: 0.9rem; }
    .post-meta {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      color: var(--muted);
      font-size: 0.85rem;
      margin-top: 1rem;
    }
    .kind {
      color: var(--rust);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.7rem;
    }
    .badge {
      background: #f1e9dd;
      color: var(--rust);
      border-radius: 999px;
      padding: 0.1rem 0.5rem;
      font-size: 0.72rem;
      font-weight: 700;
    }
    .post h1 {
      font-size: 2rem;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0.3rem 0 0.7rem;
    }
    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 1.3rem;
    }
    .prose :global(h2) { font-size: 1.4rem; margin: 1.8rem 0 0.6rem; }
    .prose :global(h3) { font-size: 1.15rem; margin: 1.4rem 0 0.5rem; }
    .prose :global(p) { margin: 0 0 1rem; }
    .prose :global(ul), .prose :global(ol) { margin: 0 0 1rem; padding-left: 1.3rem; }
    .prose :global(li) { margin: 0.25rem 0; }
    .prose :global(a) { color: var(--rust); text-decoration: underline; }
    .prose :global(blockquote) {
      margin: 1rem 0;
      padding: 0.4rem 1rem;
      border-left: 3px solid var(--rust);
      color: var(--muted);
    }
    .fonti {
      margin-top: 2.5rem;
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }
    .fonti h2 { font-size: 1.1rem; }
    .fonti ul { padding-left: 1.2rem; color: var(--muted); font-size: 0.95rem; }
    .fonti a { color: var(--rust); }
  </style>
</Base>
