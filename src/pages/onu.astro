---
import Base from '../layouts/Base.astro'
import {
  supabase,
  VACANCY_FIELDS,
  STATI_VISIBILI,
  dataItaliana,
  giorniAllaScadenza,
  type Vacancy,
} from '../lib/supabase'

const { data, error } = await supabase
  .from('vacancy')
  .select(VACANCY_FIELDS)
  .in('stato', STATI_VISIBILI)
  .order('scadenza', { ascending: true, nullsFirst: false })
  .order('ente', { ascending: true })

const vacancies = (data ?? []) as Vacancy[]

// Metadati delle 4 organizzazioni (nome esteso).
const ORG_INFO: Record<string, { full: string }> = {
  FAO: { full: 'Food and Agriculture Organization' },
  WFP: { full: 'World Food Programme' },
  IFAD: { full: 'International Fund for Agricultural Development' },
  'Bioversity-CIAT': { full: 'Alliance Bioversity International – CIAT' },
}
const ORDINE = ['FAO', 'WFP', 'IFAD', 'Bioversity-CIAT']

function sede(v: Vacancy): string {
  const s = (v.sedi ?? []).filter(Boolean).join(' · ')
  if (v.home_based) return s ? `${s} · da remoto` : 'Da remoto'
  return s || '—'
}

// View-model: tutti i calcoli (giorni, urgenza, etichette) sono qui nel frontmatter,
// per non usare operatori "<"/"<=" dentro il template (rotti dal parser Astro).
type Riga = {
  titolo: string
  url: string
  sede: string
  tipo: string | null
  scadenzaFmt: string | null
  urgente: boolean
  giorniLabel: string
}

const gruppi = ORDINE.map((ente) => {
  const items = vacancies.filter((v) => v.ente === ente)
  const righe: Riga[] = items.map((v) => {
    const giorni = giorniAllaScadenza(v.scadenza)
    let giorniLabel = ''
    if (giorni !== null && giorni >= 0) {
      giorniLabel = giorni === 0 ? 'oggi' : `tra ${giorni} g`
    }
    return {
      titolo: v.titolo,
      url: v.url,
      sede: sede(v),
      tipo: v.tipo_contratto,
      scadenzaFmt: v.scadenza ? dataItaliana(v.scadenza) : null,
      urgente: giorni !== null && giorni >= 0 && giorni <= 7,
      giorniLabel,
    }
  })
  return {
    ente,
    info: ORG_INFO[ente] ?? { full: ente },
    portale: items.find((v) => v.fonte_url)?.fonte_url ?? null,
    righe,
  }
}).filter((g) => g.righe.length > 0)
---

<Base
  title="Lavoro nelle organizzazioni internazionali — SwipeIt Lavoro"
  description="Posizioni aperte in FAO, WFP, IFAD e Alliance Bioversity-CIAT. Aggiornate ogni giorno."
>
  <section class="hero">
    <h1>Lavoro nelle organizzazioni internazionali</h1>
    <p class="lead">
      Posizioni aperte nelle agenzie ONU e nei centri di ricerca con sede a Roma.
      Aggiornate ogni notte. Candidature sui portali ufficiali delle organizzazioni.
    </p>
  </section>

  {error && <p class="err">Errore nel caricamento: {error.message}</p>}
  {
    !error && vacancies.length === 0 && (
      <p class="muted">Nessuna posizione aperta al momento.</p>
    )
  }

  {/* Le 4 organizzazioni, con link ai portali ufficiali */}
  <ul class="orgs">
    {
      gruppi.map((g) => (
        <li class="org">
          <div class="org-head">
            <span class="org-name">{g.ente}</span>
            <span class="org-count">{g.righe.length}</span>
          </div>
          <span class="org-full">{g.info.full}</span>
          {g.portale && (
            <a class="org-link" href={g.portale} target="_blank" rel="noopener">
              Portale carriere →
            </a>
          )}
        </li>
      ))
    }
  </ul>

  {/* Elenco posizioni, raggruppate per organizzazione */}
  {
    gruppi.map((g) => (
      <section class="group">
        <h2 class="group-title">
          {g.ente} <span class="group-sub">{g.info.full}</span>
        </h2>
        <ul class="jobs">
          {g.righe.map((r) => (
            <li class="job">
              <a href={r.url} target="_blank" rel="noopener">
                <h3>{r.titolo}</h3>
                <div class="job-meta">
                  <span class="loc">{r.sede}</span>
                  {r.tipo && <span class="ctype">{r.tipo}</span>}
                </div>
              </a>
              {r.scadenzaFmt ? (
                <span class={r.urgente ? 'deadline urgent' : 'deadline'}>
                  Scade il {r.scadenzaFmt}
                  {r.giorniLabel && <small> · {r.giorniLabel}</small>}
                </span>
              ) : (
                <span class="deadline open">Candidatura aperta</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))
  }

  <style>
    .hero { padding: 1.5rem 0 0.5rem; }
    .hero h1 {
      font-size: 2rem;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin: 0.2rem 0 0.6rem;
    }
    .lead { color: var(--muted); font-size: 1.05rem; margin: 0; }
    .err { color: #b3261e; }

    .orgs {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0 2rem;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
    }
    .org {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .org-head { display: flex; align-items: baseline; gap: 0.5rem; }
    .org-name { font-weight: 800; letter-spacing: -0.01em; }
    .org-count {
      margin-left: auto;
      background: #f1e9dd;
      color: var(--rust);
      border-radius: 999px;
      padding: 0.05rem 0.55rem;
      font-size: 0.8rem;
      font-weight: 700;
    }
    .org-full { color: var(--muted); font-size: 0.82rem; line-height: 1.3; }
    .org-link {
      margin-top: 0.4rem;
      color: var(--rust);
      font-weight: 600;
      font-size: 0.85rem;
      text-decoration: none;
    }

    .group { margin: 2rem 0 0; }
    .group-title {
      font-size: 1.05rem;
      margin: 0 0 0.7rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid var(--border);
    }
    .group-sub { color: var(--muted); font-weight: 400; font-size: 0.85rem; }

    .jobs { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
    .job {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.85rem 1rem;
    }
    .job > a { display: block; text-decoration: none; }
    .job h3 { font-size: 1rem; line-height: 1.35; margin: 0 0 0.35rem; }
    .job-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.8rem;
      color: var(--muted);
      font-size: 0.85rem;
    }
    .ctype {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0 0.5rem;
      font-size: 0.78rem;
    }
    .deadline {
      display: inline-block;
      margin-top: 0.5rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--rust);
      background: #f1e9dd;
      border-radius: 999px;
      padding: 0.12rem 0.6rem;
    }
    .deadline small { font-weight: 400; opacity: 0.8; }
    .deadline.urgent { color: #fff; background: #c0392b; }
    .deadline.open { color: var(--muted); background: transparent; padding-left: 0; }
    .job:hover { border-color: var(--rust); }
    @media (max-width: 560px) {
      .orgs { grid-template-columns: 1fr; }
    }
  </style>
</Base>
