---
import Base from '../layouts/Base.astro'
import {
  supabase,
  ARTICOLO_FIELDS,
  STATI_VISIBILI,
  articoloSlug,
  dataItaliana,
  type Articolo,
} from '../lib/supabase'

const { data, error } = await supabase
  .from('articoli')
  .select(ARTICOLO_FIELDS)
  .in('stato', STATI_VISIBILI)
  .order('data_sessione', { ascending: false })
  .order('id', { ascending: false })

const articoli = (data ?? []) as Articolo[]

function estratto(md: string | null, n = 180): string {
  if (!md) return ''
  const txt = md
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
    .replace(/[#>*_`~]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
  return txt.length > n ? txt.slice(0, n).trimEnd() + '…' : txt
}
---

<Base title="My Italian Job — il lavoro in Italia, spiegato">
  <section class="hero">
    <h1>Il lavoro in Italia, spiegato.</h1>
    <p class="lead">
      Inchieste, dati e analisi su occupazione, contratti, concorsi pubblici e
      diritti.
    </p>
  </section>

  {error && <p class="err">Errore nel caricamento: {error.message}</p>}
  {
    !error && articoli.length === 0 && (
      <p class="muted">Nessun articolo pubblicato al momento.</p>
    )
  }

  <ul class="cards">
    {
      articoli.map((a) => (
        <li class="card">
          <a href={`/articolo/${articoloSlug(a)}`}>
            <div class="card-meta">
              <time>{dataItaliana(a.data_sessione)}</time>
              {a.stato !== 'ACTIVE' && <span class="badge">{a.stato}</span>}
            </div>
            <h2>{a.argomento}</h2>
            <p>{estratto(a.testo_markdown)}</p>
            <span class="more">Leggi →</span>
          </a>
        </li>
      ))
    }
  </ul>

  <style>
    .hero { padding: 1.5rem 0 1rem; }
    .hero h1 {
      font-size: 2rem;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin: 0.2rem 0 0.6rem;
    }
    .lead { color: var(--muted); font-size: 1.05rem; margin: 0; }
    .err { color: #b3261e; }
    .cards {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0 0;
      display: grid;
      gap: 1rem;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
    }
    .card a { display: block; text-decoration: none; padding: 1.1rem 1.2rem; }
    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--muted);
      font-size: 0.85rem;
    }
    .badge {
      background: #f1e9dd;
      color: var(--rust);
      border-radius: 999px;
      padding: 0.1rem 0.5rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.03em;
    }
    .card h2 { font-size: 1.2rem; line-height: 1.3; margin: 0.4rem 0; }
    .card p { color: var(--muted); margin: 0 0 0.6rem; }
    .more { color: var(--rust); font-weight: 600; font-size: 0.9rem; }
    .card:hover { border-color: var(--rust); }
  </style>
</Base>
