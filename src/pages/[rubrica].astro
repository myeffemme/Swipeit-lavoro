---
import Base from '../layouts/Base.astro'
import ArticoloCard from '../components/ArticoloCard.astro'
import { fetchArticoli, RUBRICHE, rubricaDi, type Articolo } from '../lib/supabase'

// Una pagina per ogni rubrica con elenco proprio: /longform, /dal-mondo, /storia, /trend.
export async function getStaticPaths() {
  const articoli = await fetchArticoli()
  return RUBRICHE.map((r) => ({
    params: { rubrica: r.slug },
    props: { r, articoli: articoli.filter((a) => rubricaDi(a) === r.key) },
  }))
}

const { r, articoli } = Astro.props as {
  r: (typeof RUBRICHE)[number]
  articoli: Articolo[]
}
const inEvidenza = articoli[0]
const altri = articoli.slice(1)
---

<Base title={`${r.titolo} — myitalianjob`} description={r.descrizione}>
  <section class="hero">
    <h1>{r.titolo}</h1>
    <p class="lead">{r.descrizione}</p>
  </section>

  {articoli.length === 0 && <p class="muted vuoto">Ancora nessun contenuto in questa sezione.</p>}

  {inEvidenza && <ArticoloCard a={inEvidenza} featured />}

  {
    altri.length > 0 && (
      <>
        <h2 class="sezione">Altri in {r.label}</h2>
        <ul class="cards">
          {altri.map((a) => (
            <li>
              <ArticoloCard a={a} />
            </li>
          ))}
        </ul>
      </>
    )
  }

  <style>
    .hero { padding: 1.5rem 0 0.5rem; }
    .hero h1 {
      font-size: 2.1rem;
      line-height: 1.12;
      letter-spacing: -0.02em;
      margin: 0.2rem 0 0.6rem;
    }
    .lead { color: var(--muted); font-size: 1.05rem; margin: 0; }
    .vuoto { margin-top: 1.5rem; }
    .sezione {
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin: 2rem 0 0.8rem;
    }
    .cards {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(2, 1fr);
    }
    @media (max-width: 560px) {
      .cards { grid-template-columns: 1fr; }
    }
  </style>
</Base>
