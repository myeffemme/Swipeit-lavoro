---
import type { Tag } from '../lib/supabase'
interface Props {
  tag: Tag
  size?: 'sm' | 'md'
}
const { tag, size = 'md' } = Astro.props
---

<span class={`tag ${size}`} style={`--tag-bg:${tag.bg};--tag-fg:${tag.fg}`}>{tag.label}</span>

<style>
  .tag {
    display: inline-block;
    background: var(--tag-bg);
    color: var(--tag-fg);
    border-radius: 999px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }
  .md {
    font-size: 0.72rem;
    padding: 0.3rem 0.6rem;
    letter-spacing: 0.01em;
  }
  .sm {
    font-size: 0.64rem;
    padding: 0.22rem 0.48rem;
  }
</style>
